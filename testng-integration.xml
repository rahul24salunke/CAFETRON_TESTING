<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cafetron Integration UI Suite" verbose="1" parallel="false">
    <listeners>
        <listener class-name="com.cafetron.listeners.TestListener"/>
    </listeners>
    <test name="Integration">
        <groups>
            <run>
                <include name="integration"/>
            </run>
        </groups>
        <classes>
            <class name="com.cafetron.tests.menu.MenuBrowsingTests"/>
            <class name="com.cafetron.tests.cart.CartTests"/>
            <class name="com.cafetron.tests.checkout.CheckoutTests"/>
            <class name="com.cafetron.tests.wallet.WalletTests"/>
            <class name="com.cafetron.tests.orders.OrdersAndQrTests"/>
            <class name="com.cafetron.tests.vendor.VendorTests"/>
            <class name="com.cafetron.tests.e2e.EndToEndTests"/>
            <class name="com.cafetron.tests.defects.DefectRegressionTests"/>
        </classes>
    </test>
</suite>
