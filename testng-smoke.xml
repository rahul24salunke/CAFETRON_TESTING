<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cafetron Smoke UI Suite" verbose="1" parallel="false">
    <listeners>
        <listener class-name="com.cafetron.listeners.TestListener"/>
    </listeners>
    <test name="Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.cafetron.tests.auth.LoginTests"/>
            <class name="com.cafetron.tests.menu.MenuBrowsingTests"/>
            <class name="com.cafetron.tests.cart.CartTests"/>
            <class name="com.cafetron.tests.wallet.WalletTests"/>
            <class name="com.cafetron.tests.vendor.VendorTests"/>
            <class name="com.cafetron.tests.admin.AdminTests"/>
            <class name="com.cafetron.tests.rbac.AccessControlTests"/>
        </classes>
    </test>
</suite>
