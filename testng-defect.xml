<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cafetron Defect Regression UI Suite" verbose="1" parallel="false">
    <listeners>
        <listener class-name="com.cafetron.listeners.TestListener"/>
    </listeners>
    <test name="Defect Regression">
        <groups>
            <run>
                <include name="defect"/>
            </run>
        </groups>
        <classes>
            <class name="com.cafetron.tests.registration.RegistrationTests"/>
            <class name="com.cafetron.tests.defects.DefectRegressionTests"/>
        </classes>
    </test>
</suite>
