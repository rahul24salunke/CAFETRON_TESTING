<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cafetron RBAC UI Suite" verbose="1" parallel="false">
    <listeners>
        <listener class-name="com.cafetron.listeners.TestListener"/>
    </listeners>
    <test name="RBAC">
        <groups>
            <run>
                <include name="rbac"/>
            </run>
        </groups>
        <classes>
            <class name="com.cafetron.tests.auth.LoginTests"/>
            <class name="com.cafetron.tests.admin.AdminTests"/>
            <class name="com.cafetron.tests.rbac.AccessControlTests"/>
            <class name="com.cafetron.tests.defects.DefectRegressionTests"/>
        </classes>
    </test>
</suite>
