<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cafetron E2E UI Suite" verbose="1" parallel="false">
    <listeners>
        <listener class-name="com.cafetron.listeners.TestListener"/>
    </listeners>
    <test name="E2E">
        <groups>
            <run>
                <include name="e2e"/>
            </run>
        </groups>
        <classes>
            <class name="com.cafetron.tests.e2e.EndToEndTests"/>
        </classes>
    </test>
</suite>
